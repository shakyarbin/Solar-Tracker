#include <ESP32Servo.h>
#include <Adafruit_INA219.h>
#include <WiFi.h>
#include <Firebase_ESP_Client.h>

Servo servov;
Servo servoh;

Adafruit_INA219 ina219;
FirebaseData fbdo;
FirebaseAuth auth;
FirebaseConfig config;
FirebaseJson json;
FirebaseJson servos;

const char* ssid = "ashok@vianet_2.4G";
const char* password = "ashok9413";
const char* API = "AIzaSyAYqCJVluZkW4BXrXbOHZvFIbiK4hEH71Y";
const char* DATABASE_URL = "https://solar-tracker-36ba3-default-rtdb.asia-southeast1.firebasedatabase.app";

int LDR1;
int LDR2;
int LDR3;
int LDR4;

int posv=0;
int posh=0;

String mode= "track";

float voltage;
float current;
float power;

unsigned long lastFirebaseUpdate = 0;
const unsigned long firebaseInterval = 4000;

void setup() {
  Serial.begin(115200);

  ina219.begin();
  ina219.setCalibration_32V_2A();
  Serial.println("RESTARTED");

  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED){
    Serial.print(".");
    delay(500);
  }

  Serial.println("\nConnected");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  config.api_key = API;
  config.database_url = DATABASE_URL;
  auth.user.email = "notarbin99@gmail.com";
  auth.user.password = "Testing";
  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);

  pinMode(32, INPUT);
  pinMode(33, INPUT);
  pinMode(34, INPUT);
  pinMode(35, INPUT);
  servov.attach(19);
  servoh.attach(18);
  posv=90;
  posh=90;
  servov.write(posv);
  servoh.write(posh);
}

void loop() {
  

  if (mode == "storm"){
    posv = 90;
    posh = 90;
    servov.write(posv);
    servoh.write(posh);
  }

  else{
    LDR1 = analogRead(32);
    LDR2 = analogRead(33);
    LDR3 = analogRead(34);
    LDR4 = analogRead(35);
    Serial.print("LDR1: ");
    Serial.print(LDR1);
    Serial.print("  LDR2: ");
    Serial.print(LDR2);
    Serial.print("  LDR3: ");
    Serial.print(LDR3);
    Serial.print("  LDR4: ");
    Serial.println(LDR4);

    int verticalError = LDR1 - LDR2;
    int horizontalError = LDR4 - LDR3;

    if (abs(verticalError)>150){
      if((LDR1 < LDR2) && posv<100){
        posv ++;
      }

      else if ((LDR1 > LDR2) && posv>0){
        posv --;
      }
    }


      if (abs(horizontalError)>150){
        if((LDR4 < LDR3) && posh<180){
          posh ++;
      }
      else if((LDR4 > LDR3) && posh>0){
        posh --;
      }
    }
    Serial.print("Vertical: ");
    Serial.print(posv);
    Serial.print("  Horizontal: ");
    Serial.println(posh);
    servov.write(posv);
    servoh.write(posh);
  }


  if (millis() - lastFirebaseUpdate >= firebaseInterval) {

    // if (Firebase.RTDB.getString(&fbdo, "/mode")){
    //   mode = fbdo.stringData();
    //   Serial.print("Mode: ");
    //   Serial.println(mode);
    // }

    lastFirebaseUpdate = millis();
    voltage = ina219.getBusVoltage_V();
    current = ina219.getCurrent_mA();
    power = ina219.getPower_mW();

    if (current< 0.3) current = 0;

    Serial.print("Voltage: ");
    Serial.print(voltage);
    Serial.println("v");
    Serial.print("Current: ");
    Serial.print(current);
    Serial.println("mA");
    Serial.print("Power: ");
    Serial.print(power);
    Serial.println("mW");
    Serial.println();

    if (Firebase.ready()) {
      
      json.set("voltage", voltage);
      json.set("current", current);
      json.set("power", power);
      servos.set("azimuth", posh);
      servos.set("elevation", posv);
      
      bool ok1 = Firebase.RTDB.pushJSON(&fbdo, "/SolarTracker", &json);
      bool ok2 = Firebase.RTDB.setJSON(&fbdo, "/SolarTrackerControls", &servos);
      
      if (ok1 && ok2) {
        Serial.println("Uploaded");
      }
      else {
        Serial.println(fbdo.errorReason());
      }
    }
  }

  delay(50);
}
